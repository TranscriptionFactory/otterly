{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "badgerly",
  "version": "1.0.0",
  "identifier": "com.badgerly.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build && pnpm build:excalidraw",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../build"
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "excalidraw-dist/*",
      "excalidraw-dist/assets/*",
      "resources/extensions/*",
      "resources/models/**/*"
    ],
    "macOS": {
      "signingIdentity": "-"
    },
    "fileAssociations": [
      {
        "ext": ["md", "markdown", "mdown", "mkd", "mkdn", "mdwn", "mdx"],
        "name": "Markdown Document",
        "mimeType": "text/markdown",
        "role": "Editor"
      },
      {
        "ext": ["txt"],
        "name": "Text Document",
        "mimeType": "text/plain",
        "role": "Editor"
      },
      {
        "ext": ["canvas"],
        "name": "JSON Canvas",
        "mimeType": "application/json",
        "role": "Editor"
      },
      {
        "ext": ["excalidraw"],
        "name": "Excalidraw Drawing",
        "mimeType": "application/json",
        "role": "Editor"
      }
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEVEMkY0REEwMEVGODhEQkYKUldTL2pmZ09vRTB2N1p4bWhJRGxkc2lZLy9ocTU3b2VBT1R5NHVtSzNsWFpzTDVWckQ4cnhSbEsK",
      "endpoints": [
        "https://github.com/TranscriptionFactory/otterly/releases/latest/download/latest.json"
      ]
    }
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "badgerly",
        "width": 1200,
        "height": 820,
        "resizable": true,
        "dragDropEnabled": false,
        "zoomHotkeysEnabled": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: blob: badgerly-asset: badgerly-plugin:; style-src 'self' 'unsafe-inline'; script-src 'self' blob: badgerly-plugin:; worker-src 'self' blob:; connect-src ipc: http://ipc.localhost badgerly-asset:; frame-src badgerly-plugin: badgerly-excalidraw:"
    }
  }
}
